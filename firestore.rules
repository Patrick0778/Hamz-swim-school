rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public products for the shop listing
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Public settings for marquee/poster reading
    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Availability calendar for lessons
    match /availability/{dateId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Restrict everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}